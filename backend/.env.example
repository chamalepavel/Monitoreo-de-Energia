# ============================================================
# .env.example — PLANTILLA de variables de entorno
# ============================================================
# ¿QUÉ ES ESTE ARCHIVO?
# Es una plantilla que muestra qué variables necesitas configurar.
# Las variables de entorno son como "configuraciones secretas" que
# NO queremos escribir directamente en el código (por seguridad).
#
# ¿QUÉ DEBES HACER?
# 1. Copia este archivo y renómbralo a ".env" (sin el .example)
# 2. Rellena los valores con los tuyos
# 3. NUNCA subas el archivo ".env" a GitHub (tiene datos secretos)
#    El archivo ".env.example" SÍ se puede subir, es solo la plantilla.
# ============================================================


# --- SERVIDOR ---
# Puerto donde correrá tu backend. El 4000 es una buena opción
# porque React suele usar el 3000 y así no hay conflicto.
PORT=4000


# --- BASE DE DATOS ---
# Datos para conectarse a PostgreSQL corriendo en Docker.
# Deben coincidir exactamente con lo que pusiste en docker-compose.yml
DB_HOST=localhost
DB_PORT=5432
DB_NAME=monitoreo_solar
DB_USER=admin
DB_PASSWORD=admin123


# --- AUTH0 ---
# Estos datos los obtienes de tu panel de Auth0.
# IMPORTANTE: Sin estos datos, la autenticación no funcionará.
#
# AUTH0_DOMAIN: Lo encuentras en Applications > Tu App > Domain
#   Ejemplo: mi-proyecto.us.auth0.com
#
# AUTH0_AUDIENCE: Lo encuentras en APIs > Tu API > API Audience (Identifier)
#   Ejemplo: https://monitoreo-solar-api
AUTH0_DOMAIN=TU_DOMINIO.us.auth0.com
AUTH0_AUDIENCE=TU_AUDIENCE_AQUI


# --- FRONTEND ---
# La URL donde corre tu React, para permitir las conexiones (CORS)
FRONTEND_URL=http://localhost:3000
